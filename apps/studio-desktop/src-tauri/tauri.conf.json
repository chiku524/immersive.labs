{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Immersive Studio",
  "version": "0.1.0",
  "identifier": "space.immersivelabs.studio",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173/studio",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Immersive Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "url": "/studio"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/setup-desktop-studio.ps1"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
