{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Immersive Studio",
  "version": "0.1.4",
  "identifier": "space.immersivelabs.studio",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Immersive Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "url": "/desktop/launch",
        "visible": false,
        "center": true,
        "resizable": true
      },
      {
        "label": "splashscreen",
        "title": "Immersive Studio",
        "width": 420,
        "height": 320,
        "url": "/desktop/splash",
        "visible": true,
        "center": true,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        "updater-all"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "resources": [
      "resources/setup-desktop-studio.ps1",
      "resources/comfy_silent_launcher.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDMDlBQzI2RTQ2ODREQUMKUldTc1RXamtKcXdKUEsyQ0VjbnJQaGM1Mi9KUGdrTlRLaGl4WFhvRDNtbEZpa056dCtwYzk1YUUK",
      "endpoints": [
        "https://github.com/chiku524/immersive.labs/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
