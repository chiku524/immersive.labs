# Copy to .env and fill in. Never commit real secrets.

# --- Stripe (same mode: test vs live for all three) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: pin API version (match Dashboard webhook "API version" if desired)
# STRIPE_API_VERSION=2026-03-25.dahlia

# Recurring Price ids from Stripe Dashboard (Products → Price id)
STUDIO_STRIPE_PRICE_INDIE=price_...
STUDIO_STRIPE_PRICE_TEAM=price_...

# Or map multiple prices: price_aaa:indie,price_bbb:team
# STUDIO_STRIPE_PRICE_MAP=

# Checkout / Portal return URLs (production HTTPS)
# STUDIO_BILLING_SUCCESS_URL=https://yourdomain/studio?billing=success
# STUDIO_BILLING_CANCEL_URL=https://yourdomain/studio?billing=cancel
# STUDIO_BILLING_PORTAL_RETURN_URL=https://yourdomain/studio

# SaaS mode: required for Checkout + Portal from /studio UI
# STUDIO_API_AUTH_REQUIRED=1

# Optional: POST JSON when customer.subscription.trial_will_end (Zapier / Slack / custom)
# STUDIO_TRIAL_END_NOTIFY_WEBHOOK_URL=https://hooks.zapier.com/...
