# Copy to .env and fill in. Never commit real secrets.
#
# Local PC (Comfy + Blender + API on one machine): see
#   scripts/local-pc-studio/README.md
# and copy scripts/local-pc-studio/env.studio-worker.local.template → .env.local

# --- Writable data (jobs, queue.sqlite, tenants.sqlite) ---
# Default: ~/.immersive-studio/worker when STUDIO_REPO_ROOT is unset (PyPI / pip install).
# Monorepo Docker / dev: set STUDIO_REPO_ROOT to repo root → uses apps/studio-worker/output.
# Override explicitly:
# STUDIO_WORKER_DATA_DIR=/var/lib/immersive-studio

# --- Full jobs (textures + mesh) ---
# ComfyUI: worker calls HTTP(S) APIs at this base URL (no trailing slash). Local dev:
# STUDIO_COMFY_URL=http://127.0.0.1:8188
#
# Production (Immersive Labs hosted ComfyUI):
STUDIO_COMFY_URL=https://comfy.immersivelabs.space
# STUDIO_COMFY_PROFILE=sd15
# STUDIO_COMFY_CHECKPOINT=v1-5-pruned-emaonly.safetensors
# Blender for placeholder GLB export (--export-mesh); if not on PATH, set full path to blender.exe:
# STUDIO_BLENDER_BIN=
# Optional: always export mesh when the API does not pass export_mesh (default off):
# STUDIO_EXPORT_MESH_DEFAULT=1

# --- Browser CORS (comma-separated, no spaces required) ---
# Every origin users type in the address bar to open /studio must be listed (scheme + host, no path).
# Production (immersivelabs.space example):
# STUDIO_CORS_ORIGINS=https://immersivelabs.space,https://www.immersivelabs.space
# Include Cloudflare Pages preview hosts too if previews call this worker:
# STUDIO_CORS_ORIGINS=https://branch.project.pages.dev,https://immersivelabs.space,https://www.immersivelabs.space
#
# Docker / systemd: pass the same string in -e STUDIO_CORS_ORIGINS='...' (see README).

# --- Ollama (LLM spec generation; omit if using mock mode only) ---
# STUDIO_OLLAMA_URL=http://127.0.0.1:11434
# STUDIO_OLLAMA_MODEL=tinyllama
# Read timeout for POST /api/chat (seconds, clamped 30–3600; base default 1800 when unset).
# The client retries once after a read timeout using ~1.5× this base (capped at 3600s per attempt).
# Raising the base keeps the queue worker blocked longer — prefer a smaller model, more RAM/swap,
# or /studio "mock" for UI tests. GCE: clear or raise STUDIO_OLLAMA_READ_TIMEOUT_S metadata if still 900s.
# STUDIO_OLLAMA_READ_TIMEOUT_S=2400
#
# --- Production (Cloudflare Worker + tunnel + small VM) ---
# Keep tunnel DNS for api-origin DNS-only (grey cloud); watch cloudflared + uvicorn logs on 502s.
# Ollama + Comfy + Blender on one tiny VM causes timeouts and intermittent 502 — scale VM or split queue worker (STUDIO_EMBEDDED_QUEUE_WORKER=0). See apps/studio-edge/README.md and docs/studio/essentials.md.
# Optional: queue job SSE (`/queue/jobs/{id}/events`) server poll interval in seconds (0.25–10, default 1).
# STUDIO_QUEUE_SSE_POLL_S=1
#
# Optional: POST /api/studio/queue/jobs rate limit per API key (sliding 60s window). 0 = disabled.
# STUDIO_RATE_LIMIT_ENQUEUE_PER_MINUTE=60
#
# Optional: use Ollama streaming /api/chat (may help large outputs; validate for your model).
# STUDIO_OLLAMA_STREAM=1

# --- Stripe (same mode: test vs live for all three) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: pin API version (match Dashboard webhook "API version" if desired)
# STRIPE_API_VERSION=2026-03-25.dahlia

# Recurring Price ids from Stripe Dashboard (Products → Price id)
STUDIO_STRIPE_PRICE_INDIE=price_...
STUDIO_STRIPE_PRICE_TEAM=price_...

# Or map multiple prices: price_aaa:indie,price_bbb:team
# STUDIO_STRIPE_PRICE_MAP=

# Checkout / Portal return URLs (production HTTPS)
# STUDIO_BILLING_SUCCESS_URL=https://yourdomain/studio?billing=success
# STUDIO_BILLING_CANCEL_URL=https://yourdomain/studio?billing=cancel
# STUDIO_BILLING_PORTAL_RETURN_URL=https://yourdomain/studio

# SaaS mode: required for Checkout + Portal from /studio UI
# STUDIO_API_AUTH_REQUIRED=1

# Optional: POST JSON when customer.subscription.trial_will_end (Zapier / Slack / custom)
# STUDIO_TRIAL_END_NOTIFY_WEBHOOK_URL=https://hooks.zapier.com/...
