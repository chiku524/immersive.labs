# Copy to apps/studio-worker/.env.scale (gitignored) for docker-compose.scale.yml
# and scripts/studio-scale/run-local-queue-worker.*

# --- Postgres (Phase C) — use Neon in prod or local-db compose profile ---
# Neon: Dashboard → Connection string → postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://studio:studio@postgres:5432/studio

# local-db profile only (docker compose --profile local-db):
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio
POSTGRES_DB=studio
POSTGRES_PUBLISH_PORT=5432

STUDIO_QUEUE_BACKEND=postgres
STUDIO_TENANTS_BACKEND=postgres

# --- R2 artifacts (Phase A) — Cloudflare R2 → Manage R2 API tokens ---
STUDIO_JOB_ARTIFACTS=r2
STUDIO_S3_BUCKET=your-bucket-name
STUDIO_S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STUDIO_S3_REGION=auto
STUDIO_S3_KEY_PREFIX=immersive-studio/packs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- API / CORS ---
STUDIO_API_PUBLISH=8787
STUDIO_CORS_ORIGINS=https://immersivelabs.space,https://www.immersivelabs.space,http://127.0.0.1:5173,http://localhost:5173

# --- Split queue (Phase B) — API container sets STUDIO_EMBEDDED_QUEUE_WORKER=0 ---
STUDIO_QUEUE_WORKER_ID=compose-q-1
STUDIO_QUEUE_POLL_INTERVAL=1

# --- LLM / Comfy (point local worker at host services) ---
STUDIO_COMFY_URL=https://comfy.immersivelabs.space
STUDIO_OLLAMA_URL=http://127.0.0.1:11434
STUDIO_OLLAMA_MODEL=tinyllama
# STUDIO_OLLAMA_DISABLED=1

# STUDIO_QUEUE_MAX_JOB_AGE_S=28800
