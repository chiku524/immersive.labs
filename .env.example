# Copy to `.env` at the **repository root** (gitignored). Used by:
#   scripts/studio-cloudflare-tunnel/preflight-studio-public-api.sh
#   scripts/studio-cloudflare-tunnel/cf-tunnel-admin.sh
#
# --- API token (User cfut_… or Account cfat_…) ---
# Must include **Account → Cloudflare Tunnel → Read** to call GET …/cfd_tunnel/{id}.
# Account-owned tokens (cfat_…) verify with:
#   GET https://api.cloudflare.com/client/v4/accounts/{CF_ACCOUNT_ID}/tokens/verify
# CLOUDFLARE_API_TOKEN=
# CF_ACCOUNT_ID=
# CF_TUNNEL_ID=
#
# --- Optional: Global API Key (only if token cannot be granted Tunnel Read without dashboard) ---
# Profile → API Keys → Global API Key. Prefer minting a scoped User token once:
#   bash scripts/studio-cloudflare-tunnel/cf-bootstrap-user-token.sh
# CF_AUTH_EMAIL=
# CF_GLOBAL_API_KEY=
#
# --- Optional: Vercel CLI (npm run deploy:web) ---
# VERCEL_TOKEN=           # CI / non-interactive deploy
# VERCEL_SCOPE=nico-builds  # Team slug → passes --scope (alias: VERCEL_TEAM)
