# Copy to apps/studio-worker/.env.local (gitignored) — free local stack template.
#   copy scripts\local-pc-studio\env.studio-worker.local.template apps\studio-worker\.env.local
# Then edit STUDIO_REPO_ROOT and STUDIO_BLENDER_BIN for your machine.

STUDIO_REPO_ROOT=C:/Users/you/Desktop/vibe-code/immersive.labs

# Real specs via Ollama (leave Mock OFF in /studio). Requires: ollama pull llama3.2
STUDIO_OLLAMA_URL=http://127.0.0.1:11434
STUDIO_OLLAMA_MODEL=llama3.2

# Free mesh: headless Blender GLB (procedural placeholder from spec — not prompt-to-mesh AI).
STUDIO_MESH_PROVIDER=blender_placeholder
STUDIO_BLENDER_BIN=C:/Program Files/Blender Foundation/Blender 5.1/blender.exe

# Optional albedo/ORM textures via ComfyUI (separate install + start-comfyui.ps1).
STUDIO_COMFY_URL=http://127.0.0.1:8188

STUDIO_EMBEDDED_QUEUE_WORKER=1
STUDIO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Do NOT set STUDIO_OLLAMA_DISABLED=1 unless you want mock specs only.
# Do NOT set STUDIO_MESH_PROVIDER=tripo unless you have Tripo OpenAPI credits.
