{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://immersive.labs/schemas/studio-job-manifest-v0.1.json",
  "title": "StudioJobManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "job_id", "created_at", "engine_target", "assets", "toolchain"],
  "properties": {
    "manifest_version": { "const": "0.1" },
    "job_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "engine_target": { "const": "unity" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" },
      "description": "Each element must satisfy studio-asset-spec-v0.1 (validated separately in tooling)."
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "llm_model": { "type": "string" },
        "image_pipeline": { "type": "string" },
        "mesh_pipeline": { "type": "string" },
        "unity_urp_version": { "type": "string" }
      }
    }
  }
}
